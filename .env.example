# PostgreSQL database connection URL
DATABASE_URL="postgres://postgres:DO_NOT_USE_ME@db/solana-verified-programs-api"

# PostgreSQL password
POSTGRES_PASSWORD="DO_NOT_USE_ME"

# PostgreSQL database name
POSTGRES_DB="solana-verified-programs-api"

# Docker default platform
DOCKER_DEFAULT_PLATFORM=""

# Primary RPC URL
RPC_URL=""

# Secret key for webhook authentication
AUTH_SECRET="DO_NOT_USE_ME"

# Port to run the API server on
PORT=3000

# Docker resource limits for solana-verify
SVB_DOCKER_CPU_LIMIT=4
SVB_DOCKER_MEMORY_LIMIT=8g

# Interval (seconds) for the program_state sweep loop. Default 5 minutes.
SWEEP_INTERVAL_SECONDS=300
